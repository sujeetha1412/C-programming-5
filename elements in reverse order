#include<stdio.h>
int main()
{
   int num[50];
   int n,i;
   printf("Enter the total no.of.elements:");
   scanf("%d",&n);
   printf("Enter the elements:\n");
   for(i=0;i<n;i++)
   {
      scanf("%d",&num[i]);
   }
   printf("The elements are:\n");
   for(i=0;i<n;i++)
   {
      printf("%d\t",num[i]);
   }
   printf("\nelements in reverse order:\t");
   for(i=n-1;i>=0;i--)
   {
      printf("%d\t",num[i]);
   }
   return 0;
}
