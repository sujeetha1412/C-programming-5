#include<stdio.h>
int main()
{
   int num[50];
   int n,i,max;
   printf("Enter the total no.of.elements:");
   scanf("%d",&n);
   printf("Enter the elements:\n");
   for(i=0;i<n;i++)
   {
      scanf("%d",&num[i]);
   }
   printf("The elements are:");
   for(i=0;i<n;i++)
   {
      printf("%d \t",num[i]);
   }
   max=num[0];
   for(i=1;i<n;i++)
   {
      if(num[i]>max)
      {
         max=num[i];
      }
   }
   printf("\nThe max element:%d",max);
   return 0;
}
