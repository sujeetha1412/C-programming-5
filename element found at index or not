#include<stdio.h>
int main()
{
   int a[100],key,i,n,flag;
   printf("Enter number of elements:");
   scanf("%d",&n);
   printf("Enter the elements:\n");
   for(i=0;i<n;i++)
   {
       scanf("%d",&a[i]);
   }
   printf("Enter key to be searched:\n");
   scanf("%d",&key);
   for(i=0;i<n;i++)
   {
      if(a[i]==key)
      {
         flag=1;
         printf("Element found at index %d",i);
         break;
      }
   }
   if(flag==0)
   {
     printf("Element is not found");
   }
   return 0;
}
