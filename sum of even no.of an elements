#include<stdio.h>
int main()
{
   int num[100];
   int n,i,sum=0;
   printf("Enter the total no.of.elements:");
   scanf("%d",&n);
   printf("Enter the elements:\n");
   for(i=0;i<n;i++)
   {
      scanf("%d",&num[i]);
   }
   printf("The elements are:");
   for(i=0;i<n;i++)
   {
      printf("%d \t",num[i]);
   }
   for(i=0;i<n;i++)
   {
      if(i%2==0)
      {
         sum+=num[i];
      }
   }
   printf("\nSum of even no.of an elements:%d",sum);
   return 0;
}
